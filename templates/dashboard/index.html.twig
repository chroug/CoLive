{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord - CoLive{% endblock %}

{% block body %}
    {% include '_navbar.html.twig' %}

    <div class="container mt-5 mb-5" style="font-family: 'Poppins', sans-serif;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>

                <h1 style="margin: 0; font-size: 2rem; font-weight: bold;">Bonjour, {{ app.user.prenom }} !</h1>
            </div>
            <a href="{{ path('app_announce_create') }}" class="btn btn-dark rounded-pill px-4">+ Ajouter un logement</a>
        </div>

        <p class="text-muted mb-5">Bienvenue sur votre espace propriétaire. Voici l'état de vos locations.</p>

        <div class="row mb-5">
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 rounded-4 p-3 text-center" style="background: #f8fafc;">
                    <div class="text-muted small fw-bold text-uppercase mb-2">Mes Logements</div>
                    <h3 class="mb-0 fw-bolder">{{ total_annonces }}</h3>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 rounded-4 p-3 text-center" style="background: #eff6ff;">
                    <div class="text-primary small fw-bold text-uppercase mb-2">Locataires Actuels</div>
                    <h3 class="mb-0 fw-bolder text-primary">{{ reservations_en_cours|length }}</h3>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 rounded-4 p-3 text-center" style="background: #f0fdf4;">
                    <div class="text-success small fw-bold text-uppercase mb-2">Réservations (Total)</div>
                    <h3 class="mb-0 fw-bolder text-success">{{ total_reservations }}</h3>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 rounded-4 p-3 text-center" style="background: #fffbeb;">
                    <div class="text-warning small fw-bold text-uppercase mb-2">Revenus Actuels</div>
                    <h3 class="mb-0 fw-bolder text-warning">{{ revenus_mensuels }} € <span class="fs-6 text-muted">/mois</span></h3>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="card shadow-sm border-0 rounded-4 p-4" style="background-color: #f8fafc;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                            <polyline points="9 22 9 12 15 12 15 22"></polyline>
                        </svg>

                        <h2 style="margin: 0; font-size: 1.25rem; font-weight: 500;">Actuellement dans vos logements</h2>
                    </div>

                    {% if reservations_en_cours is empty %}
                        <p class="text-muted">Personne n'occupe vos logements en ce moment.</p>
                    {% else %}
                        <div class="d-flex flex-column gap-3">
                            {% for res in reservations_en_cours %}
                                <div class="p-3 bg-white rounded-3 shadow-sm border" style="border-left: 4px solid #10b981 !important;">
                                    <strong>{{ res.announce.titre }}</strong><br>
                                    <span class="text-muted small">
                                        Occupé par <b>{{ res.locataire.prenom }} {{ res.locataire.nom }}</b><br>
                                        Jusqu'au {{ res.dateFin|date('d/m/Y') }}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="col-lg-7 mb-4">
                <div class="card shadow-sm border-0 rounded-4 p-4">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>

                        <h2 style="margin: 0; font-size: 1.25rem; font-weight: 500;">Planning des réservations à venir</h2>
                    </div>

                    {% if reservations_a_venir is empty %}
                        <p class="text-muted">Aucune réservation à venir pour le moment.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                <tr>
                                    <th>Logement</th>
                                    <th>Locataire</th>
                                    <th>Arrivée</th>
                                    <th>Départ</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for res in reservations_a_venir %}
                                    <tr>
                                        <td class="fw-bold">{{ res.announce.titre }}</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="bg-light rounded-circle p-1 px-2 border">{{ res.locataire.prenom|slice(0,1) }}</span>
                                                {{ res.locataire.prenom }}
                                            </div>
                                        </td>
                                        <td class="text-success fw-semibold">{{ res.dateDebut|date('d/m/Y') }}</td>
                                        <td class="text-danger">{{ res.dateFin|date('d/m/Y') }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
