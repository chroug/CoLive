{% extends 'base.html.twig' %}

{% block title %}Se connecter{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/registration.css') }}">
{% endblock %}

{% block body %}
    <div class="auth-bg">
        <img src="{{ asset('img/home.png') }}" alt="CoLive Background" class="hero-bg-image">
        <div class="auth-center">
            <section class="auth-card" style="position: relative;">

                <div style="text-align: left; margin-bottom: 20px;">
                    <a href="{{ path('app_home') }}" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: #64748b; font-weight: 600; font-size: 0.95rem; font-family: 'Poppins', sans-serif; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                        </svg>
                        Retour à l'accueil
                    </a>
                </div>

                <div class="logo-box">C</div>
                <h2 class="title">Connexion</h2>
                <p class="subtitle">Heureux de vous revoir !</p>

                <form action="{{ path('app_login') }}" method="post" class="form">

                    <label for="username">Email</label>
                    <input type="email" id="username" name="_username" value="{{ last_username }}" placeholder="votre.email@example.com" required autofocus>

                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="_password" placeholder="......." required>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    {% if error %}
                        <div class="flash-error">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <button type="submit" class="btn-primary">Se connecter</button>
                </form>

                <p class="login-link">
                    Pas encore de compte ? <a href="{{ path('app_registration') }}">S'inscrire</a>
                </p>

            </section>
        </div>
    </div>
{% endblock %}
