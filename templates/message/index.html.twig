{% extends 'base.html.twig' %}

{% block title %}Messagerie{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/message.css') }}">
{% endblock %}

{% block body %}
    <div class="messagerie-wrapper">
        <div class="messagerie-container">
            <div class="messagerie-sidebar">
                <div class="sidebar-header">
                    <div class="brand-logo">C</div>
                    <h2>Messagerie</h2>
                </div>
                <div class="search-box">
                    <form action="{{ path('app_message') }}" method="get">
                        <input type="text"
                               name="q"
                               value="{{ searchTerm }}"
                               placeholder="Rechercher un contact"
                               autocomplete="off">
                        <button type="submit" style="display: none;"></button>
                    </form>
                </div>
                <div class="contact-list">
                    <h3>Mes Discussions ({{ users|length }})</h3>
                    <div class="list-scroll" id="contactListContainer">
                        {% for user in users %}
                            <div class="contact-item-wrapper" style="position: relative;">
                                <a href="{{ path('app_message_conversation', {id: user.id}) }}"
                                   class="contact-card {{ selectedUser and selectedUser.id == user.id ? 'active' : '' }}"
                                   data-name="{{ user.prenom|lower }} {{ user.nom|lower }}">
                                    <div class="avatar">{{ user.prenom|first|upper }}</div>
                                    <div class="info">
                                        <span class="name">{{ user.prenom }} {{ user.nom }}</span>
                                        <span class="sub-text">Voir la conversation</span>
                                    </div>
                                </a>
                            </div>
                        {% else %}
                            <div style="padding: 20px; text-align: center; color: #777;">
                                <p>Aucune discussion en cours.</p>
                                <small>Contactez un membre via une annonce pour démarrer une discussion.</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="messagerie-content">
                {% if selectedUser %}
                    <div class="chat-header">
                        <div class="avatar">{{ selectedUser.prenom|first|upper }}</div>
                        <h3>{{ selectedUser.prenom }} {{ selectedUser.nom }}</h3>
                    </div>

                    <div class="messages-area" id="messagesArea">
                        {% for message in messages %}
                            <div class="message-row {{ message.sender.id == app.user.id ? 'sent' : 'received' }}">
                                {% if message.sender.id != app.user.id %}
                                    <div class="message-avatar">{{ message.sender.prenom|first }}</div>
                                {% endif %}

                                <div class="message-bubble">
                                    {% if message.attachment %}
                                        <div class="message-image">
                                            <img src="{{ asset('uploads/' ~ message.attachment) }}" alt="Pièce jointe">
                                        </div>
                                    {% endif %}

                                    {% if message.content %}
                                        <p>{{ message.content }}</p>
                                    {% endif %}

                                    <small class="message-time">{{ message.createdAt|date('H:i') }}</small>
                                </div>
                            </div>
                        {% else %}
                            <div class="empty-chat">Nouvelle discussion. Dites bonjour !</div>
                        {% endfor %}
                    </div>
                    <div class="input-area">
                        <form method="post" class="input-form" enctype="multipart/form-data">
                            <label for="file-upload" class="btn-attachment" title="Ajouter une image"><svg  xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                                                                            fill="#000000" viewBox="0 0 24 24" >
                                    <!--Boxicons v3.0.6 https://boxicons.com | License  https://docs.boxicons.com/free-->
                                    <path d="m20,4h-8.59l-1.41-1.41c-.38-.38-.88-.59-1.41-.59h-4.59c-1.1,0-2,.9-2,2v14c0,1.1.9,2,2,2h16c1.1,0,2-.9,2-2V6c0-1.1-.9-2-2-2Zm0,2v3H4v-3h16ZM4,18v-7h16v7H4Z"></path>
                                </svg></label>
                            <input id="file-upload" type="file" name="file_upload" style="display: none;" accept="image/*">

                            <input type="text" name="content" placeholder="Écrivez votre message..." autocomplete="off">
                            <button type="submit" class="btn-send">Envoyer</button>
                        </form>
                        <div id="file-name-display" style="font-size: 0.8rem; color: #666; margin-top: 5px; margin-left: 10px;"></div>
                    </div>

                {% else %}
                    <div class="no-selection">
                        <p>Sélectionnez une discussion à gauche.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
