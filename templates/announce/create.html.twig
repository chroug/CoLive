{% extends 'base.html.twig' %}

{% block title %}Créer une annonce{% endblock %}

{% block stylesheets %}
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        .form-control, .form-select {
            background-color: #f8f9fa;
            border: 0.0625rem solid #e9ecef;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
        }
        .form-control:focus, .form-select:focus {
            background-color: #fff;
            box-shadow: 0 0 0 0.25rem rgba(0,0,0,0.05);
            border-color: #dee2e6;
        }
        .card {
            border: none;
            box-shadow: 0 0.25rem 1.5rem rgba(0,0,0,0.06);
        }
        .upload-area {
            border: 0.125rem dashed #dee2e6;
            transition: all 0.3s ease;
        }
        .upload-area:hover {
            border-color: #adb5bd;
            background-color: #f8f9fa;
        }
    </style>
{% endblock %}

{% block body %}

    <div style="background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('{{ asset('img/home.png') }}') no-repeat center center fixed; background-size: cover; min-height: 100vh; padding-top: 3rem; padding-bottom: 5rem;">

        <div class="container" style="max-width: 53rem;">

            <div class="mb-4 text-start">
                <a href="{{ path('app_home') }}" class="text-decoration-none">
                    <span class="bg-black text-white d-inline-flex align-items-center justify-content-center rounded-3 fw-bold" style="width: 2.5rem; height: 2.5rem; font-size: 1.2rem;">C</span>
                </a>
            </div>

            {{ form_start(formAnnonce) }}

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Informations de base</h5>
                <p class="text-muted small mb-4">Décrivez votre logement en quelques mots</p>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Titre de l'annonce <span class="text-danger">*</span></label>
                            {{ form_widget(formAnnonce.titre, {'attr': {'class': 'form-control', 'placeholder': 'Ex : Chambre confortable près de l\'université'}}) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Type de logement <span class="text-danger">*</span></label>
                            {{ form_widget(formAnnonce.type, {'attr': {'class': 'form-select'}}) }}
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold small">Nombre de pièces <span class="text-danger">*</span></label>
                            {{ form_widget(formAnnonce.nb_pieces, {'attr': {'class': 'form-control', 'placeholder': 'Nombre de pièces'}}) }}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div>
                            <label class="form-label fw-bold small">Description <span class="text-danger">*</span></label>
                            {{ form_widget(formAnnonce.description, {'attr': {'class': 'form-control', 'style': 'height: 14rem; resize: none;', 'placeholder': 'Décrivez votre logement, l\'ambiance, les avantages...'}}) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Localisation</h5>
                <p class="text-muted small mb-4">Où se trouve votre logement ?</p>
                <div class="mb-3">
                    <label class="form-label fw-bold small">Adresse <span class="text-danger">*</span></label>
                    {{ form_widget(formAnnonce.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Numéro et nom de rue'}}) }}
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Ville <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.ville, {'attr': {'class': 'form-control', 'placeholder': 'Ville'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Code postal <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.code_postal, {'attr': {'class': 'form-control', 'placeholder': 'Code postal'}}) }}
                    </div>
                </div>
                <div class="d-none">
                    {{ form_widget(formAnnonce.latitude, {'value': '0'}) }}
                    {{ form_widget(formAnnonce.longitude, {'value': '0'}) }}
                </div>
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Tarification</h5>
                <p class="text-muted small mb-4">Définissez le prix de votre logement</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Surface (m²) <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.surface, {'attr': {'class': 'form-control', 'placeholder': '25'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Prix par mois (€) <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.prix, {'attr': {'class': 'form-control', 'placeholder': '450'}}) }}
                    </div>
                </div>
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Photos</h5>
                <p class="text-muted small mb-4">Ajoutez des photos de votre logement (optionnel)</p>
                <div class="upload-area rounded-4 p-5 text-center d-flex flex-column align-items-center justify-content-center bg-white" style="min-height: 12.5rem;">
                    <button type="button" class="btn btn-outline-dark rounded-pill px-4 py-2 mb-3 fw-medium">Choisir des fichiers</button>
                    <p class="text-muted small mb-0">Glissez-déposez vos photos ici ou cliquez pour sélectionner</p>
                </div>
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Équipements et services</h5>
                <p class="text-muted small mb-4">Quels équipements sont disponibles ?</p>
                <label class="form-label fw-bold small">Liste des équipements <span class="text-danger">*</span></label>
                {{ form_widget(formAnnonce.equipements, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Wifi, Cuisine équipée, Lave-linge...'}}) }}
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Disponibilité</h5>
                <p class="text-muted small mb-4">Quand votre logement est-il disponible ?</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Disponible à partir du <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.disponibilite_debut, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Disponible jusqu'au <span class="text-danger">*</span></label>
                        {{ form_widget(formAnnonce.disponibilite_fin, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>
            </div>

            <div class="card rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-1">Règles du logement</h5>
                <p class="text-muted small mb-4">Y a-t-il des règles particulières à respecter ?</p>
                <label class="form-label fw-bold small">Règles et informations complémentaires</label>
                {{ form_widget(formAnnonce.regle, {'attr': {'class': 'form-control', 'placeholder': 'Ex : Pas de fêtes, respect du calme après 22h, etc.'}}) }}
            </div>

            <div class="text-center pb-5">
                <button type="submit" class="btn btn-light bg-white fw-bold px-5 py-3 rounded-pill shadow-lg border-0" style="font-size: 1.1rem;">
                    Publier l'annonce
                </button>
            </div>

            {{ form_end(formAnnonce) }}
        </div>
    </div>
{% endblock %}
