{% extends 'base.html.twig' %}

{% block title %}Toutes nos annonces{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/announce_index.css') }}">

{% endblock %}

{% block body %}

    <div class="main-wrapper">

        <nav style="display:flex; justify-content:space-between; align-items:center; padding:15px 5%; background:white; border-bottom:1px solid #eaeaea; position:sticky; top:0; z-index:1000; height: 75px;">
            <div style="display:flex; align-items:center; gap:15px;">
                <a href="javascript:history.back()" style="color:black; font-size:1.5rem; text-decoration:none;" title="Retour"><i class="bi bi-arrow-left"></i></a>
                <a href="{{ path('app_home') }}" style="font-weight:bold; font-size:1.2rem; display:flex; align-items:center; gap:8px; text-decoration:none; color:black;">
                    <span style="background:black; color:white; padding:2px 8px; border-radius:6px; font-weight:900;">C</span> CoLive
                </a>
            </div>

            <div style="display:flex; align-items:center; gap:15px;">
                {% if app.user %}
                    <a href="{{ path('app_bot') }}" style="color:black; text-decoration:none; display:flex; align-items:center; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'" title="Assistant Bot">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M8.5 10a1.5 2 0 1 0 0 4 1.5 2 0 1 0 0-4M15.5 10a1.5 2 0 1 0 0 4 1.5 2 0 1 0 0-4M8 16h8v2H8z"></path><path d="M21 11V8c0-1.1-.9-2-2-2h-6V4.61c.3-.27.5-.67.5-1.11 0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5c0 .44.2.84.5 1.11V6H5c-1.1 0-2 .9-2 2v3c-.55 0-1 .45-1 1v4c0 .55.45 1 1 1v3c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-3c.55 0 1-.45 1-1v-4c0-.55-.45-1-1-1M5 20V8h14v12z"></path></svg>
                    </a>

                    <a href="{{ path('app_message') }}" style="color:black; text-decoration:none; display:flex; align-items:center; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'" title="Mes messages">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="m21.55,8.17l-2.55-1.7v-1.46c0-.55-.45-1-1-1h-2.7l-2.75-1.83c-.34-.22-.77-.22-1.11,0l-2.75,1.83h-2.7c-.55,0-1,.45-1,1v1.46l-2.55,1.7c-.28.19-.45.5-.45.83v11c0,1.1.9,2,2,2h16c1.1,0,2-.9,2-2v-11c0-.33-.17-.65-.45-.83Zm-14.55-2.17h10v4.46l-5,3.33-5-3.33v-4.46Zm-3,14v-9.13l1.45.96,6,4c.17.11.36.17.55.17s.39-.06.55-.17l6-4,1.45-.96v9.13H4Z"></path></svg>
                    </a>

                    <a href="{{ path('app_profile') }}" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:black; background:#f9fafb; padding:5px 15px 5px 5px; border-radius:50px; font-weight:600; border: 1px solid #eaeaea; transition: background 0.2s;" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='#f9fafb'">
                        {% if app.user.avatar %}
                            <img src="{{ app.user.avatar }}" alt="Avatar" style="width:34px; height:34px; border-radius:50%; object-fit:cover;">
                        {% else %}
                            <img src="https://ui-avatars.com/api/?name={{ app.user.prenom }}+{{ app.user.nom }}&background=000&color=fff" alt="Avatar" style="width:34px; height:34px; border-radius:50%;">
                        {% endif %}
                        <span>{{ app.user.prenom }}</span>
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" style="background:black; color:white; padding:8px 20px; border-radius:50px; text-decoration:none; font-weight:bold; font-size: 0.95rem; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">Se connecter</a>
                {% endif %}
            </div>
        </nav>

        <div class="filter-overlay" id="overlay" onclick="toggleMenu()"></div>

        <aside class="filter-sidebar" id="sidebar">
            <div class="sidebar-header">
                <h2 class="sidebar-title">Filtres</h2>
                <button class="btn-close" onclick="toggleMenu()">&times;</button>
            </div>

            <form action="{{ path('app_announce') }}" method="get">
                <div>
                    <label for="location" class="form-label">Ville</label>
                    <input type="text" id="location" name="location" value="{{ app.request.query.get('location') }}" class="form-input" placeholder="Ex: Paris">
                </div>

                <div style="height: 50px;" class="desktop-hidden"></div>

                <fieldset class="form-fieldset">
                    <legend class="form-legend">Type de logement</legend>

                    {% set currentFilter = app.request.query.get('type', 'all') %}

                    <div>
                        <input type="radio" id="type_all" name="type" value="all" class="radio-hidden"
                               {% if currentFilter == 'all' %}checked{% endif %}>
                        <label for="type_all" class="radio-text-label">Tout</label>
                    </div>

                    <div>
                        <input type="radio" id="type_chambre" name="type" value="Chambre" class="radio-hidden"
                               {% if currentFilter == 'Chambre' %}checked{% endif %}>
                        <label for="type_chambre" class="radio-text-label">Chambre</label>
                    </div>

                    <div>
                        <input type="radio" id="type_coloc" name="type" value="Colocation" class="radio-hidden"
                               {% if currentFilter == 'Colocation' %}checked{% endif %}>
                        <label for="type_coloc" class="radio-text-label">Colocation</label>
                    </div>

                    <div>
                        <input type="radio" id="type_studio" name="type" value="Studio" class="radio-hidden"
                               {% if currentFilter == 'Studio' %}checked{% endif %}>
                        <label for="type_studio" class="radio-text-label">Studio</label>
                    </div>

                </fieldset>

                <div style="height: 50px;" class="desktop-hidden"></div>

                <fieldset class="form-fieldset">
                    <legend class="form-legend">Période</legend>
                    <div style="margin-bottom:30px;">
                        <label class="form-label">Arrivée</label>
                        <input type="date" name="date_start" class="form-input" value="{{ app.request.query.get('date_start') }}">
                    </div>
                    <div>
                        <label class="form-label">Départ</label>
                        <input type="date" name="date_end" class="form-input" value="{{ app.request.query.get('date_end') }}">
                    </div>
                </fieldset>

                <button type="submit" class="btn-submit">Voir les résultats</button>

                <a href="{{ path('app_announce') }}" class="btn-reset-filters">
                    Réinitialiser les filtres
                </a>
            </form>
        </aside>

        <section>
            <div class="page-header-container">
                <h1 class="page-title">Toutes nos annonces
                {% if app.request.query.get('type') != 'all' %}
                    de {{ app.request.query.get('type') }}
                {% endif %}
                </h1>

                <button class="btn-filter-text" onclick="toggleMenu()">
                    <i class="bi bi-filter"></i> Filtres
                </button>
            </div>

            <div class="pinterest-grid">
                {% for announce in announces %}
                    <article class="announce-card" onclick="window.location.href='{{ path('app_announce_show', {'id': announce.id}) }}'">
                        {% set isLiked = false %}
                        {% if app.user %}
                            {% for like in announce.likes %}
                                {% if like.utilisateur == app.user %}
                                    {% set isLiked = true %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}

                        <button class="card-like-btn {{ isLiked ? 'liked' : '' }}"
                                onclick="toggleLike(event, {{ announce.id }})">
                            <i class="bi {{ isLiked ? 'bi-heart-fill' : 'bi-heart' }}"></i>
                        </button>

                        {% set photo = announce.photos|first %}
                        {% if photo %}
                            <img src="{{ photo.contenu }}" class="card-img" alt="Photo">
                        {% else %}
                            <img src="https://picsum.photos/seed/{{ announce.id }}/400/600" class="card-img" alt="Defaut">
                        {% endif %}
                        <div class="card-content">
                            <h2 class="card-title">{{ announce.titre }}</h2>
                            <p class="card-location"><i class="bi bi-geo-alt-fill"></i> {{ announce.ville }}</p>
                            {% if announce.disponibiliteDebut and announce.disponibiliteFin %}
                                <p class="card-date">
                                    {{ announce.disponibiliteDebut|date('d M') }} - {{ announce.disponibiliteFin|date('d M') }}
                                </p>
                            {% endif %}
                            <div class="card-price">{{ announce.prix }}€ <small>/mois</small></div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>

    </div>

    <script>
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');
        }
        async function toggleLike(event, announceId) {
            event.stopPropagation();
            event.preventDefault();

            {% if not app.user %}
            window.location.href = "{{ path('app_login') }}";
            return;
            {% endif %}

            const btn = event.currentTarget;
            const icon = btn.querySelector('i');

            try {
                const response = await fetch('/announce/' + announceId + '/like', {
                    method: 'POST'
                });

                if (response.ok) {
                    const data = await response.json();

                    if (data.isLiked) {
                        btn.classList.add('liked');
                        btn.classList.add('animate');

                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');

                        setTimeout(() => btn.classList.remove('animate'), 400);

                    } else {
                        btn.classList.remove('liked');
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                    }
                }
            } catch (error) {
                console.error('Erreur', error);
            }
        }
    </script>
{% endblock %}
