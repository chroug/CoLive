{% extends 'base.html.twig' %}

{% block title %}{{ announce.titre }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/announce_show.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    {% include '_navbar.html.twig' %}

    <div class="main-desktop-wrapper">

        <div class="hero-wrapper" onclick="openLightbox(0)">
            <a href="javascript:history.back()" class="btn-back-floating" onclick="event.stopPropagation()">
                <i class="bi bi-arrow-left"></i>
            </a>
            {% if app.user %}
                <a href="{{ path('app_profile') }}" class="btn-profile-floating" onclick="event.stopPropagation()">
                    {% if app.user.avatar %}
                        <img src="{{ app.user.avatar }}" alt="Avatar" class="nav-avatar-mini">
                    {% else %}
                        <img src="https://ui-avatars.com/api/?name={{ app.user.prenom }}+{{ app.user.nom }}&background=000&color=fff&size=256&font-size=0.33" alt="Avatar" class="nav-avatar-mini">
                    {% endif %}
                </a>
            {% endif %}

            {% if announce.photos is not empty %}
                <img src="{{ announce.photos|first.contenu }}" class="hero-img" alt="Photo principale">
                <div class="photo-count-badge">1 / {{ announce.photos|length }}</div>
            {% else %}
                <img src="https://via.placeholder.com/1200x600?text=Pas+de+photo" class="hero-img" alt="Pas de photo">
            {% endif %}
        </div>

        <div class="content-sheet">
            <div class="left-column">

                {% if app.user and app.user.role == 2 and not announce.isValidated %}
                    <div style="background: #fff3cd; border: 1px solid #ffe69c; padding: 20px; border-radius: 12px; margin-bottom: 25px;">
                        <h5 style="margin-top: 0; color: #856404; font-size: 1.1rem;"><i class="bi bi-gear-fill"></i> Action Administrateur requise</h5>
                        <p style="color: #856404; margin-bottom: 15px;">Cette annonce est actuellement invisible pour les utilisateurs car elle est en attente de validation.</p>
                        <div style="display: flex; gap: 15px;">
                            <form action="{{ path('app_admin_announce_validate', {'id': announce.id}) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ announce.id) }}">
                                <button type="submit" style="background: #28a745; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;">
                                    <i class="bi bi-check-circle"></i> Accepter
                                </button>
                            </form>
                            <form action="{{ path('app_admin_announce_reject', {'id': announce.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir refuser et supprimer définitivement cette annonce ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ announce.id) }}">
                                <button type="submit" style="background: #dc3545; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;">
                                    <i class="bi bi-trash"></i> Refuser
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}

                <div class="title-row">
                    <h1 class="announce-title">{{ announce.titre }}</h1>
                    <button class="btn-like-big {% if app.user and announce.isLikedByUser(app.user) %}liked{% endif %}"
                            data-token="{{ csrf_token('like' ~ announce.id) }}"
                            onclick="toggleLike(event, {{ announce.id }}, this)">
                        <i class="bi {% if app.user and announce.isLikedByUser(app.user) %}bi-heart-fill{% else %}bi-heart{% endif %}"></i>
                    </button>
                </div>

                <div class="announce-location">
                    <i class="bi bi-geo-alt"></i> {{ announce.ville }}
                </div>

                <ul class="tags-list">
                    <li class="tag-pill"><i class="bi bi-house"></i> {{ announce.type }}</li>
                    <li class="tag-pill"><i class="bi bi-people"></i> Colocation</li>
                </ul>

                <div class="host-card">
                    {% if announce.utilisateur.avatar %}
                        <img src="{{ announce.utilisateur.avatar }}" alt="Hôte" class="host-avatar">
                    {% else %}
                        <img src="https://ui-avatars.com/api/?name={{ announce.utilisateur.prenom }}+{{ announce.utilisateur.nom }}&background=000&color=fff" alt="Hôte" class="host-avatar">
                    {% endif %}
                    <div class="host-info">
                        <h3>Hôte : {{ announce.utilisateur.prenom }}</h3>
                        <p>Membre depuis {{ announce.utilisateur.dateCreationCompte|date('Y') }}</p>
                    </div>
                </div>

                <h2 class="section-title">À propos de ce logement</h2>
                <div class="text-content">
                    {{ announce.description|nl2br }}
                </div>

                {% if announce.photos|length > 1 %}
                    <h2 class="section-title">Galerie</h2>
                    <div class="mini-gallery">
                        {% for i in 1..(announce.photos|length - 1) %}
                            {% if announce.photos[i] is defined %}
                                <img src="{{ announce.photos[i].contenu }}" alt="Photo {{ i+1 }}" onclick="openLightbox({{ i }})">
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="desktop-sidebar-wrapper">
                <div class="booking-card">
                    <div class="card-price-row">
                        <span class="card-price-amount">{{ announce.prix }}€</span>
                        <span class="card-price-label">/ mois</span>
                    </div>
                    <div class="card-dates-box">
                        <div class="card-date-line">
                            <span>Disponibilité</span>
                            <span class="card-date-val">Immédiate</span>
                        </div>
                        <div class="card-date-line">
                            <span>Frais de service</span>
                            <span class="card-date-val">0€</span>
                        </div>
                    </div>
                    <a href="{{ path('app_reservation_reserve', {'id': announce.id}) }}" class="btn-card-action btn-reserve-desk">Réserver maintenant</a>
                    <a href="mailto:{{ announce.utilisateur.email }}" class="btn-card-action btn-contact-desk">Contacter l'hôte</a>
                </div>
            </div>
        </div>

        <div class="spacer-footer"></div>
    </div>

    <div class="fixed-bottom-bar">
        <div class="price-row">
            <span class="price-amount">{{ announce.prix }}€</span>
            <span class="price-label">/ mois</span>
        </div>
        <div class="buttons-row">
            <a href="mailto:{{ announce.utilisateur.email }}" class="btn-action btn-contact">Contact</a>
            <a href="{{ path('app_reservation_reserve', {'id': announce.id}) }}" class="btn-action btn-reserve">Réserver</a>
        </div>
    </div>

    <div id="lightbox" class="lightbox">
        <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
        <div class="lightbox-nav">
            <button class="lightbox-btn" onclick="prevImage()"><i class="bi bi-chevron-left"></i></button>
            <button class="lightbox-btn" onclick="nextImage()"><i class="bi bi-chevron-right"></i></button>
        </div>
        <img id="lightboxImg" src="" class="lightbox-img" alt="Zoom Photo">
    </div>

    <script>
        let currentImgIndex = 0;
        const photos = [
            {% for photo in announce.photos %}
            "{{ photo.contenu }}"{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        function openLightbox(index) {
            if (photos.length === 0) return;
            currentImgIndex = index;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
            document.getElementById('lightbox').classList.add("active");
            document.body.style.overflow = "hidden";
        }

        function closeLightbox() {
            document.getElementById('lightbox').classList.remove("active");
            document.body.style.overflow = "auto";
        }

        function nextImage() {
            currentImgIndex = (currentImgIndex + 1) % photos.length;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
        }

        function prevImage() {
            currentImgIndex = (currentImgIndex - 1 + photos.length) % photos.length;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
        }

        async function toggleLike(event, announceId, btn) {
            event.stopPropagation();
            const icon = btn.querySelector('i');

            const csrfToken = btn.getAttribute('data-token');
            const formData = new FormData();
            if (csrfToken) {
                formData.append('_token', csrfToken);
            }

            try {
                const response = await fetch('/announce/' + announceId + '/like', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();

                    if (data.isLiked) {
                        btn.classList.add('liked');
                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');
                    } else {
                        btn.classList.remove('liked');
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                    }
                } else {
                    console.error("Erreur de sécurité ou accès non autorisé.");
                }
            } catch (error) { console.error(error); }
        }

        let touchStartX = 0;
        let touchEndX = 0;
        const lightbox = document.getElementById('lightbox');

        lightbox.addEventListener('touchstart', e => touchStartX = e.changedTouches[0].screenX);
        lightbox.addEventListener('touchend', e => {
            touchEndX = e.changedTouches[0].screenX;
            if (touchEndX < touchStartX - 50) nextImage();
            if (touchEndX > touchStartX + 50) prevImage();
        });

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") closeLightbox();
            if (event.key === "ArrowRight") nextImage();
            if (event.key === "ArrowLeft") prevImage();
        });
    </script>
{% endblock %}
