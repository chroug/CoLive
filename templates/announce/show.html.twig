{% extends 'base.html.twig' %}

{% block title %}{{ announce.titre }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/announce_show.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}

    {% include '_navbar.html.twig' %}

    <div class="main-desktop-wrapper">

        <div class="hero-wrapper" id="heroWrapper">

            <a href="javascript:history.back()" class="btn-back-floating" onclick="event.stopPropagation()">
                <i class="bi bi-arrow-left"></i>
            </a>
            {% if app.user %}
                <a href="{{ path('app_profile') }}" class="btn-profile-floating" onclick="event.stopPropagation()">
                    {% if app.user.avatar %}
                        <img src="{{ app.user.avatar }}" alt="Avatar" class="nav-avatar-mini">
                    {% else %}
                        <img src="https://ui-avatars.com/api/?name={{ app.user.prenom }}+{{ app.user.nom }}&background=000&color=fff&size=256&font-size=0.33" alt="Avatar" class="nav-avatar-mini">
                    {% endif %}
                </a>
            {% endif %}

            <div class="hero-main-img" onclick="openLightbox(0)">
                {% if announce.photos is not empty %}
                    <img src="{{ announce.photos|first.contenu }}" alt="Photo principale">
                {% else %}
                    <img src="https://via.placeholder.com/1200x600?text=Pas+de+photo" alt="Pas de photo">
                {% endif %}
            </div>

            <div class="hero-side-imgs">
                {% for i in 1..2 %}
                    {% if announce.photos[i] is defined %}
                        <div class="side-img-item" onclick="openLightbox({{ i }})">
                            <img src="{{ announce.photos[i].contenu }}" alt="Photo {{ i+1 }}">
                        </div>
                    {% else %}
                        <div class="side-img-item empty"></div>
                    {% endif %}
                {% endfor %}
            </div>

            <button class="btn-all-photos" onclick="openLightbox(0)">
                <i class="bi bi-grid-3x3-gap"></i> Afficher toutes les photos
            </button>
        </div>

        <div class="content-container">
            <div class="left-column">
                <div class="header-section">
                    <div class="title-row">
                        <h1>{{ announce.titre }}</h1>
                        <button class="btn-action-circle {% if app.user and announce.isLikedByUser(app.user) %}liked{% endif %}"
                                data-token="{{ csrf_token('like' ~ announce.id) }}"
                                onclick="toggleLike(event, {{ announce.id }}, this)">
                            <i class="bi {% if app.user and announce.isLikedByUser(app.user) %}bi-heart-fill{% else %}bi-heart{% endif %}"></i>
                            <span class="likes-count">{{ announce.likes|length }}</span>
                        </button>
                    </div>
                    <p class="location-text">{{ announce.ville }} • {{ announce.type }}</p>
                    <div class="badges-row">
                        <span class="badge-item"><i class="bi bi-people"></i> Colocation</span>
                        <span class="badge-item"><i class="bi bi-shield-check"></i> Vérifié</span>
                    </div>
                </div>

                <hr class="separator">

                <div class="host-preview">
                    <div class="host-info">
                        {% if announce.utilisateur.avatar %}
                            <img src="{{ announce.utilisateur.avatar }}" alt="Hôte" class="host-avatar">
                        {% else %}
                            <img src="https://ui-avatars.com/api/?name={{ announce.utilisateur.prenom }}+{{ announce.utilisateur.nom }}&background=000&color=fff" alt="Hôte" class="host-avatar">
                        {% endif %}
                        <div>
                            <h3>Hôte : {{ announce.utilisateur.prenom }}</h3>
                            <p>Membre depuis {{ announce.utilisateur.dateCreationCompte|date('Y') }}</p>
                        </div>
                    </div>
                    <a href="{{ path('app_host_reviews', {'id': announce.utilisateur.id}) }}" class="btn-secondary">Voir les avis</a>
                </div>

                <hr class="separator">

                <div class="description-section">
                    <h2>À propos de ce logement</h2>
                    <p>{{ announce.description|nl2br }}</p>
                </div>

                <hr class="separator">

                <div class="amenities-section">
                    <h2>Ce que propose ce logement</h2>
                    <div class="amenities-grid">
                        <div class="amenity-item"><i class="bi bi-wifi"></i> Wifi haut débit</div>
                        <div class="amenity-item"><i class="bi bi-tv"></i> Télévision</div>
                        <div class="amenity-item"><i class="bi bi-p-circle"></i> Parking gratuit</div>
                        <div class="amenity-item"><i class="bi bi-wind"></i> Climatisation</div>
                        <div class="amenity-item"><i class="bi bi-egg-fried"></i> Cuisine équipée</div>
                        <div class="amenity-item"><i class="bi bi-droplet"></i> Lave-linge</div>
                    </div>
                </div>

                <hr class="separator">

                <div class="contact-card-info" style="background: #f9fafb; padding: 20px; border-radius: 12px; border: 1px solid #eee;">
                    <h2 style="margin-top: 0; font-size: 1.2rem;"><i class="bi bi-info-circle"></i> Informations de contact</h2>
                    <p style="margin-bottom: 8px;"><strong>Email :</strong> {{ announce.utilisateur.publicEmail }}</p>
                    <p style="margin-bottom: 0;"><strong>Téléphone :</strong> {{ announce.utilisateur.publicTel }}</p>
                </div>
            </div>

            <div class="right-column">
                <div class="sticky-booking-card">
                    <div class="price-header">
                        <span class="price">{{ announce.prix }}€</span>
                        <span class="per-month">/ mois</span>
                    </div>

                    <div class="booking-details-box">
                        <div class="detail-row">
                            <span>Disponibilité</span>
                            <span class="val">Immédiate</span>
                        </div>
                        <div class="detail-row">
                            <span>Frais de service</span>
                            <span class="val">0€</span>
                        </div>
                    </div>

                    <a href="{{ path('app_reservation_reserve', {'id': announce.id}) }}" class="btn-primary-large">Réserver maintenant</a>

                    <p class="no-charge-text">Aucun montant ne sera débité pour le moment</p>

                    <div class="total-row">
                        <span>Total (hors charges)</span>
                        <span>{{ announce.prix }}€</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="lightbox" class="lightbox">
        <span class="close-lightbox" onclick="closeLightbox()">&times;</span>
        <div class="lightbox-content">
            <img id="lightboxImg" src="" alt="Zoom Photo">
            <div class="lightbox-nav">
                <button onclick="prevImage()"><i class="bi bi-chevron-left"></i></button>
                <button onclick="nextImage()"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    </div>

    <script>
        // --- GESTION LIGHTBOX ---
        let currentImgIndex = 0;
        const photos = [
            {% for photo in announce.photos %}
            "{{ photo.contenu }}"{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        function openLightbox(index) {
            if (photos.length === 0) return;
            currentImgIndex = index;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
            document.getElementById('lightbox').style.display = "flex";
            document.body.style.overflow = "hidden";
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = "none";
            document.body.style.overflow = "auto";
        }

        function nextImage() {
            currentImgIndex = (currentImgIndex + 1) % photos.length;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
        }

        function prevImage() {
            currentImgIndex = (currentImgIndex - 1 + photos.length) % photos.length;
            document.getElementById('lightboxImg').src = photos[currentImgIndex];
        }

        async function toggleLike(event, announceId, btn) {
            event.stopPropagation();
            const icon = btn.querySelector('i');


            const csrfToken = btn.getAttribute('data-token');
            const formData = new FormData();
            if (csrfToken) {
                formData.append('_token', csrfToken);
            }

            try {
                const response = await fetch('/announce/' + announceId + '/like', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();

                    const countSpan = btn.querySelector('.likes-count');
                    if (countSpan && data.totalLikes !== undefined) {
                        countSpan.innerText = data.totalLikes;
                    }

                    if (data.isLiked) {
                        btn.classList.add('liked');
                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');
                    } else {
                        btn.classList.remove('liked');
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                    }
                } else {
                    console.error("Erreur de sécurité ou accès non autorisé.");
                }
            } catch (error) { console.error(error); }
        }

        let touchStartX = 0;
        let touchEndX = 0;
        const lightbox = document.getElementById('lightbox');

        lightbox.addEventListener('touchstart', e => touchStartX = e.changedTouches[0].screenX);
        lightbox.addEventListener('touchend', e => {
            touchEndX = e.changedTouches[0].screenX;
            if (touchEndX < touchStartX - 50) nextImage();
            if (touchEndX > touchStartX + 50) prevImage();
        });

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") closeLightbox();
            if (event.key === "ArrowRight") nextImage();
            if (event.key === "ArrowLeft") prevImage();
        });
    </script>

{% endblock %}
