{% extends 'base.html.twig' %}

{% block title %}Mes Notifications - CoLive{% endblock %}

{% block body %}
    {% include '_navbar.html.twig' %}

    <div class="container mt-5 mb-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold"><i class="bi bi-bell-fill text-primary"></i> Mes Notifications</h2>
        </div>

        {% if notifications is empty %}
            <div class="card shadow-sm border-0 bg-light rounded-4">
                <div class="card-body text-center p-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #adb5bd;"></i>
                    <h5 class="mt-3 mb-1 fw-semibold">Aucune notification</h5>
                    <p class="mb-0 small">C'est ici que s'afficheront vos alertes, réservations et messages.</p>
                </div>
            </div>
        {% else %}
            <div class="d-flex flex-column gap-3">
                {% for notification in notifications %}

                    {% set icon = 'bi-bell' %}
                    {% set color = '#3b82f6' %}

                    {% if notification.type == 'RESERVATION' %}
                        {% set icon = 'bi-calendar-check-fill' %}
                        {% set color = '#10b981' %}
                    {% elseif notification.type == 'validation_annonce' %}
                        {% set icon = 'bi-shield-exclamation' %}
                        {% set color = '#8b5cf6' %}
                    {% elseif notification.type == 'annonce_acceptee' %}
                        {% set icon = 'bi-check-circle-fill' %}
                        {% set color = '#10b981' %}
                    {% elseif notification.type == 'annonce_refusee' %}
                        {% set icon = 'bi-x-circle-fill' %}
                        {% set color = '#ef4444' %}
                    {% elseif notification.type == 'nouvel_avis' %}
                        {% set icon = 'bi-star-fill' %}
                        {% set color = '#f59e0b' %}
                    {% endif %}
                    <div class="bg-white p-4 d-flex gap-3 rounded-4 shadow-sm border border-light" style="border-left: 5px solid {{ color }} !important; transition: transform 0.2s;">

                        <div style="font-size: 1.6rem; color: {{ color }}; display: flex; align-items: start; margin-top: -2px;">
                            <i class="bi {{ icon }}"></i>
                        </div>

                        <div class="d-flex flex-column flex-md-row gap-3 w-100 justify-content-between align-items-start">
                            <div class="pe-md-3" style="font-size: 0.95rem; line-height: 1.5; color: #333;">
                                {{ notification.content|raw }}
                            </div>
                            <div class="text-muted text-nowrap" style="font-size: 0.85rem; padding-top: 2px;">
                                <i class="bi bi-clock"></i> {{ notification.createdAt|date('d/m/Y à H:i') }}
                            </div>
                        </div>

                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
