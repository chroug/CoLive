{% extends 'base.html.twig' %}

{% block title %}Mes Notifications - CoLive{% endblock %}

{% block body %}
    {% include '_navbar.html.twig' %}

    <div class="container mt-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-bell"></i> Mes Notifications</h2>
        </div>

        {% if notifications is empty %}
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body text-center p-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 mb-1">Aucune notification</h5>
                    <p class="mb-0 small">C'est ici que s'afficheront vos alertes de réservations et de messages.</p>
                </div>
            </div>
        {% else %}
            <div class="list-group shadow-sm">
                {% for notification in notifications %}
                    <div class="list-group-item list-group-item-action d-flex gap-3 py-3" style="border-left: 4px solid {{ notification.type == 'RESERVATION' ? '#10b981' : '#3b82f6' }};">

                        <div style="font-size: 1.5rem; color: {{ notification.type == 'RESERVATION' ? '#10b981' : '#3b82f6' }};">
                            {% if notification.type == 'RESERVATION' %}
                                <i class="bi bi-calendar-check"></i>
                            {% else %}
                                <i class="bi bi-chat-dots"></i>
                            {% endif %}
                        </div>

                        <div class="d-flex gap-2 w-100 justify-content-between align-items-center">
                            <div>
                                <p class="mb-0 fw-semibold">{{ notification.content }}</p>
                            </div>
                            <small class="text-muted text-nowrap">{{ notification.createdAt|date('d/m/Y à H:i') }}</small>
                        </div>

                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
