{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/registration.css') }}">
{% endblock %}

{% block body %}
    <div class="auth-bg">
        <img src="{{ asset('img/home.png') }}" alt="image-home-appartement">

        <div class="auth-center">
            <section class="auth-card" style="position: relative;">

                <div style="text-align: left; margin-bottom: 20px;">
                    <a href="{{ path('app_home') }}" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: #64748b; font-weight: 600; font-size: 0.95rem; font-family: 'Poppins', sans-serif; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                        </svg>
                        Retour à l'accueil
                    </a>
                </div>

                <div class="logo-box">C</div>

                <h2 class="title">Rejoindre CoLive</h2>
                <p class="subtitle">Créez votre compte pour commencer à partager des logements</p>
                <p class="small-label">Remplissez les informations ci-dessous pour vous inscrire</p>

                <form action="{{ path('app_registration') }}" method="post" class="form">

                    <div class="two-cols">
                        <div>
                            <label for="prenom">Prénom</label>
                            <input type="text" id="prenom" name="registrationForm[prenom]" placeholder="Votre Prénom" required>
                        </div>
                        <div>
                            <label for="nom">Nom</label>
                            <input type="text" id="nom" name="registrationForm[nom]" placeholder="Votre nom" required>
                        </div>
                    </div>

                    <label for="email">Email</label>
                    <input type="email" id="email" name="registrationForm[email]" placeholder="votre.email@example.com" required>

                    <label for="plainPassword_first">Mot de passe</label>
                    <input type="password" id="plainPassword_first" name="registrationForm[plainPassword][first]" placeholder="......." required>

                    <label for="plainPassword_second">Répéter le mot de passe</label>
                    <input type="password" id="plainPassword_second" name="registrationForm[plainPassword][second]" placeholder="......." required>

                    {% for message in app.flashes('error') %}
                        <div class="flash-error">{{ message }}</div>
                    {% endfor %}

                    <button type="submit" class="btn-primary">Créer mon compte</button>
                </form>

                <p class="login-link">
                    Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
                </p>

            </section>
        </div>
    </div>
{% endblock %}
